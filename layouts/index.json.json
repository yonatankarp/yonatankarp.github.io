{{- $pages := where site.RegularPages "Lang" site.Language.Lang -}}
[
{{- range $index, $page := $pages -}}
  {{- if $index }},{{ end }}
  {
    "title": {{ $page.Title | jsonify }},
    "permalink": {{ $page.RelPermalink | jsonify }},
    "summary": {{ replace (replace (($page.Description | default ($page.Summary | plainify)) | htmlUnescape) "&ndash;" "-") "&mdash;" "-" | jsonify }},
    "content": {{ replace (replace (($page.Plain | truncate 400) | htmlUnescape) "&ndash;" "-") "&mdash;" "-" | jsonify }}
  }
{{- end -}}
]
